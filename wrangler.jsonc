{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "scrap",
	"main": "src/index.ts",
    "compatibility_date": "2026-06-20",
    "compatibility_flags": [
    "nodejs_compat"
  ],
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"kv_namespaces": [
		{
			"binding": "CRAWL_CACHE",
			"id": "7991cfd213dd4ac981bbb840711d5120"
		}
	],
	"browser": {
		"binding": "BROWSER"
	}
}
